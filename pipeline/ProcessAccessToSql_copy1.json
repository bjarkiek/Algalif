{
	"name": "ProcessAccessToSql_copy1",
	"properties": {
		"description": "Downloads .mdb files from blob, reads tblTrendlog tables via ODBC, and copies data to Azure SQL",
		"activities": [
			{
				"name": "GetMdbFileList",
				"description": "List all .mdb files in the blob folder",
				"type": "GetMetadata",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "BlobMdbFile",
						"type": "DatasetReference",
						"parameters": {
							"Container": {
								"value": "@pipeline().parameters.BlobContainer",
								"type": "Expression"
							},
							"Directory": {
								"value": "@pipeline().parameters.BlobDirectory",
								"type": "Expression"
							},
							"FileName": " "
						}
					},
					"fieldList": [
						"childItems"
					],
					"storeSettings": {
						"type": "AzureBlobStorageReadSettings",
						"recursive": false
					},
					"formatSettings": {
						"type": "BinaryReadSettings"
					}
				}
			}
		],
		"parameters": {
			"BlobContainer": {
				"type": "String",
				"defaultValue": "embla"
			},
			"BlobDirectory": {
				"type": "String",
				"defaultValue": "Compass2TrendlogsLive"
			},
			"LocalTempPath": {
				"type": "String",
				"defaultValue": "C:\\AdfTemp"
			}
		},
		"annotations": [],
		"lastPublishTime": "2026-04-13T00:00:00Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}