					"FolderPath_Source": {
						"type": "String",
						"defaultValue": "Trendlog"
					},
					"Directory_Source": {
						"type": "String",
						"defaultValue": "Data"
					},
					"FolderPath_Destination": {
						"type": "String",
						"defaultValue": "embla"
					},
					"Directory_Destination": {
						"type": "String",
						"defaultValue": "Compass2TrendlogsLive"
					},
					"LastModified_From": {
						"type": "String",
						"defaultValue": "2019-03-01T00:00:00Z"
					},
					"LastModified_To": {
						"type": "String",
						"defaultValue": "2029-04-01T00:00:00Z"
					}
